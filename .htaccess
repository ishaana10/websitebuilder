# WebCraft .htaccess
# Apache rewrite + security rules

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive files
    RewriteRule ^(\.env|\.git|schema\.sql|verify_builder\.py|install\.php) - [F,L]

    # Let real files and directories through untouched
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Force correct MIME types — prevents JS files being served as text/html
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType text/html .php
</IfModule>

# Block direct access to assets/js from being rendered as a page
<FilesMatch "\.(js|css|map)$">
    <IfModule mod_headers.c>
        Header set X-Content-Type-Options "nosniff"
    </IfModule>
</FilesMatch>

# PHP error handling — suppress output that could corrupt JSON responses
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
<IfModule mod_php8.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
<IfModule mod_php7.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
